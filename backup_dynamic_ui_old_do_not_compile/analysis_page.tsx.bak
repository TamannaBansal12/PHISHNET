"use client";

import React, { useEffect, useState } from "react";
import {
  AreaChart, Area, BarChart, Bar, LineChart, Line,
  PieChart, Pie, Cell, RadarChart, Radar, PolarGrid,
  PolarAngleAxis, PolarRadiusAxis, XAxis, YAxis,
  CartesianGrid, Tooltip, ResponsiveContainer, Legend
} from "recharts";
import { Brain, Leaf, ShieldCheck, Activity, RefreshCw } from "lucide-react";

const COLORS = ["#22d3ee", "#a78bfa", "#34d399", "#fbbf24", "#fb7185"];

function ChartCard({ title, subtitle, children }: any) {
  return (
    <div className="rounded-3xl border border-white/10 bg-slate-950/80 p-6 shadow-2xl">
      <h2 className="text-xl font-bold text-white">{title}</h2>
      <p className="text-sm text-slate-400 mb-5">{subtitle}</p>
      <div className="h-[320px] w-full min-w-0">{children}</div>
    </div>
  );
}

export default function AnalysisPage() {
  const [data, setData] = useState<any>(null);
  const [loading, setLoading] = useState(true);

  async function loadAnalytics() {
    setLoading(true);
    const res = await fetch("/api/analytics", { cache: "no-store" });
    const json = await res.json();
    setData(json);
    setLoading(false);
  }

  useEffect(() => {
    loadAnalytics();
    const interval = setInterval(loadAnalytics, 10000);
    return () => clearInterval(interval);
  }, []);

  if (loading || !data) {
    return (
      <main className="min-h-screen bg-[#050816] text-white flex items-center justify-center">
        <p className="text-cyan-300 animate-pulse">Loading live PHISHNET analytics...</p>
      </main>
    );
  }

  const cards = [
    { label: "Total Scans", value: data.summary.totalScans, icon: Activity },
    { label: "High Risk Cases", value: data.summary.highRiskCases, icon: ShieldCheck },
    { label: "Model Escalations", value: data.summary.modelEscalations, icon: Brain },
    { label: "Compute Saved", value: `${data.summary.computeSaved}%`, icon: Leaf },
  ];

  return (
    <main className="min-h-screen bg-[#050816] text-white p-6 md:p-10 ml-[260px] w-[calc(100%-260px)] overflow-x-hidden">
      <section className="mb-10 rounded-3xl border border-cyan-400/20 bg-gradient-to-br from-cyan-500/10 via-slate-950 to-purple-500/10 p-8 shadow-2xl">
        <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-5">
          <div>
            <p className="text-cyan-300 text-sm uppercase tracking-[0.35em] mb-3">
              PHISHNET Live Visual Intelligence
            </p>
            <h1 className="text-4xl md:text-6xl font-bold mb-4">
              Dynamic Graphs & GreenIT Analytics
            </h1>
            <p className="text-slate-300 max-w-4xl text-lg">
              Data is fetched from a live API route and refreshes automatically every 10 seconds.
            </p>
          </div>

          <button
            onClick={loadAnalytics}
            className="rounded-2xl border border-cyan-400/30 bg-cyan-400/10 px-5 py-3 text-cyan-200 flex items-center gap-2 hover:bg-cyan-400/20"
          >
            <RefreshCw size={18} /> Refresh
          </button>
        </div>
      </section>

      <section className="grid grid-cols-1 md:grid-cols-4 gap-5 mb-10">
        {cards.map((m) => {
          const Icon = m.icon;
          return (
            <div key={m.label} className="rounded-2xl border border-white/10 bg-white/5 p-6">
              <Icon className="text-cyan-300 mb-4" />
              <p className="text-slate-400 text-sm">{m.label}</p>
              <h2 className="text-3xl font-bold mt-2">{m.value}</h2>
            </div>
          );
        })}
      </section>

      <section className="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-10">
        <ChartCard title="Real Risk by Modality" subtitle="Average risk and scan count from backend reports">
          <ResponsiveContainer width="100%" height={320}>
            <BarChart data={data.riskTrend}>
              <CartesianGrid strokeDasharray="3 3" stroke="#1e293b" />
              <XAxis dataKey="modality" stroke="#94a3b8" />
              <YAxis stroke="#94a3b8" />
              <Tooltip />
              <Legend />
              <Bar dataKey="risk" fill="#22d3ee" />
              <Bar dataKey="scans" fill="#a78bfa" />
            </BarChart>
          </ResponsiveContainer>
        </ChartCard>

        <ChartCard title="GreenIT Cost by Model Tier" subtitle="Energy, latency and carbon comparison">
          <ResponsiveContainer width="100%" height={320}>
            <BarChart data={data.greenIT}>
              <CartesianGrid strokeDasharray="3 3" stroke="#1e293b" />
              <XAxis dataKey="model" stroke="#94a3b8" />
              <YAxis stroke="#94a3b8" />
              <Tooltip />
              <Legend />
              <Bar dataKey="energy" fill="#22d3ee" />
              <Bar dataKey="latency" fill="#a78bfa" />
              <Bar dataKey="carbon" fill="#34d399" />
            </BarChart>
          </ResponsiveContainer>
        </ChartCard>

        <ChartCard title="Threat Distribution" subtitle="Live threat categories by modality">
          <ResponsiveContainer width="100%" height={320}>
            <PieChart>
              <Pie data={data.detectionSplit} dataKey="value" nameKey="name" outerRadius={110} label>
                {data.detectionSplit.map((_: any, index: number) => (
                  <Cell key={index} fill={COLORS[index % COLORS.length]} />
                ))}
              </Pie>
              <Tooltip />
              <Legend />
            </PieChart>
          </ResponsiveContainer>
        </ChartCard>

        <ChartCard title="Model Routing Usage" subtitle="Model tier selection frequency">
          <ResponsiveContainer width="100%" height={320}>
            <PieChart>
              <Pie data={data.modelUsage} dataKey="value" nameKey="name" innerRadius={70} outerRadius={115} label>
                {data.modelUsage.map((_: any, index: number) => (
                  <Cell key={index} fill={COLORS[index % COLORS.length]} />
                ))}
              </Pie>
              <Tooltip />
              <Legend />
            </PieChart>
          </ResponsiveContainer>
        </ChartCard>

        <ChartCard title="Detection Confidence Radar" subtitle="Confidence across PHISHNET modules">
          <ResponsiveContainer width="100%" height={320}>
            <RadarChart data={data.confidenceRadar}>
              <PolarGrid stroke="#334155" />
              <PolarAngleAxis dataKey="subject" stroke="#cbd5e1" />
              <PolarRadiusAxis stroke="#94a3b8" />
              <Radar dataKey="score" stroke="#22d3ee" fill="#22d3ee" fillOpacity={0.35} />
              <Tooltip />
            </RadarChart>
          </ResponsiveContainer>
        </ChartCard>

        <ChartCard title="Pipeline Stage Load" subtitle="Processing intensity across stages">
          <ResponsiveContainer width="100%" height={320}>
            <LineChart data={data.pipelineLoad}>
              <CartesianGrid strokeDasharray="3 3" stroke="#1e293b" />
              <XAxis dataKey="stage" stroke="#94a3b8" />
              <YAxis stroke="#94a3b8" />
              <Tooltip />
              <Line type="monotone" dataKey="value" stroke="#a78bfa" strokeWidth={4} dot={{ r: 6 }} />
            </LineChart>
          </ResponsiveContainer>
        </ChartCard>
      </section>
    </main>
  );
}
